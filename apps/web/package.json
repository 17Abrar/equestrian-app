{
  "name": "@equestrian/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "NODE_OPTIONS='--max-old-space-size=8192' eslint .",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "postinstall": "test -f cloudflare-env.d.ts || pnpm cf:typegen || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:prod": "env -u NO_COLOR PLAYWRIGHT_BASE_URL=https://cavaliq.com playwright test --project=api-smoke"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@clerk/nextjs": "^6.39.3",
    "@equestrian/api-client": "workspace:*",
    "@equestrian/db": "workspace:*",
    "@equestrian/email-templates": "workspace:*",
    "@equestrian/shared": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "0.10.4",
    "@react-email/components": "0.0.36",
    "@sentry/nextjs": "^10.49.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@tailwindcss/postcss": "^4.1.4",
    "@tanstack/react-query": "^5.75.5",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "0.45.2",
    "lucide-react": "0.487.0",
    "next": "^15.5.16",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.72.0",
    "resend": "^4.5.1",
    "sonner": "^2.0.3",
    "stripe": "^18.1.0",
    "svix": "^1.89.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@equestrian/eslint-config": "workspace:*",
    "@equestrian/prettier-config": "workspace:*",
    "@equestrian/typescript-config": "workspace:*",
    "@opennextjs/cloudflare": "^1.19.3",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.24.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.84.1"
  }
}
