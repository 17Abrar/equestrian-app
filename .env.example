# Audit LOW-14 (2026-05-05): this file is the copy-paste template.
# For the *why* behind each variable (where it's read, what fails when
# it's missing, prod vs dev requirements), see ENV.md at the repo root.
# Production secrets live in Cloudflare Workers Secrets (`wrangler secret
# put`) and GitHub Actions Secrets тАФ NEVER in this file.

# App
# Prod: https://cavaliq.com тАФ see DEPLOY.md for the full Cloudflare setup.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Clerk (Auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Database (Neon)
DATABASE_URL=postgresql://...
DATABASE_URL_UNPOOLED=postgresql://...

# Cloudflare R2 (File Storage)
R2_ENDPOINT=https://...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=...
R2_PUBLIC_URL=https://...

# Cloudflare deploy automation (local deploys / GitHub Actions only)
# Worker runtime does NOT read this. Keep the real token in GitHub Actions
# Secrets or a gitignored local env file when running wrangler manually.
CLOUDFLARE_API_TOKEN=

# Stripe (Payments)
# Cavaliq is NOT a Stripe Connect platform. Each club connects their own
# Stripe account directly by pasting their `sk_тАж` / `pk_тАж` / `whsec_тАж`
# into the Settings тЖТ Payments form. No platform-level Stripe env vars
# are needed in prod. The keys are encrypted into
# club_payment_accounts.encrypted_credentials and used per-club at
# payment time.

# N-Genius (Network International тАФ UAE)
# Outlet reference + API key come from the merchant portal; stored per-club.
# Override base URL for sandbox testing.
N_GENIUS_API_BASE_URL=https://api-gateway.ngenius-payments.com

# Ziina (UAE fintech)
# Audit F-25 (2026-05-07 r4): the `/api` suffix is required тАФ the runtime
# defaults (lib/payments/ziina.ts, lib/billing/platform-ziina.ts) and the
# wrangler.jsonc prod var both include it. Omitting it yields 404s on
# every payment_intents call.
ZIINA_API_BASE_URL=https://api-v2.ziina.com/api

# Platform-level Ziina API key тАФ Cavaliq's OWN Ziina merchant account.
# Used to bill clubs the monthly subscription (Starter / Growing /
# Professional). Distinct from the per-club Ziina keys clubs paste into
# Settings тЖТ Payments (those receive rider payments and live encrypted
# in club_payment_accounts.encrypted_credentials). Round 6 (platform
# subscription billing) reads this. Do NOT prefix with NEXT_PUBLIC_ тАФ
# it's a server-only secret.
PLATFORM_ZIINA_API_KEY=

# Webhook signing secret for the platform Ziina account. Configure the
# webhook in Ziina's business dashboard pointing at
# `https://cavaliq.com/api/webhooks/ziina-platform` and paste the
# signing secret here. The webhook receiver verifies the
# `X-Hmac-Signature` header against this тАФ without it, paid platform
# invoices won't auto-flip to `paid` and clubs will see stale "due"
# states even after settling.
PLATFORM_ZIINA_WEBHOOK_SECRET=

# Audit F-10 (2026-05-07 r5): drives the Ziina sandbox `test` flag for
# platform-billing payment intents. Set to `true` ONLY on staging /
# preview workers so they hit Ziina sandbox; leave unset (or `false`)
# in production. Read in apps/web/lib/billing/platform-ziina.ts.
# `assertProductionEnvConfigured` will warn if this is `true` while
# NODE_ENV === 'production'.
PLATFORM_ZIINA_TEST_MODE=

# CORS allowlist (comma-separated origins that may call our API)
CORS_ALLOWED_ORIGINS=

# Sentry alert-rules setup (scripts/setup-sentry-alerts.mjs).
# Generate at Settings тЖТ Account тЖТ API тЖТ Auth Tokens, scopes
# `alerts:write` + `project:read`. Falls back to SENTRY_AUTH_TOKEN if
# unset, but a separate user token is preferred so it doesn't share
# the build-time org token's lifecycle.
SENTRY_ALERTS_AUTH_TOKEN=sntryu_...
SENTRY_ORG_SLUG=cavaliq
SENTRY_PROJECT_SLUG=javascript-nextjs
# EU-region orgs must point at the regional API host.
SENTRY_BASE_URL=https://de.sentry.io
# Optional knobs for setup-sentry-alerts.mjs тАФ see audit F-4.
# `SENTRY_ENVIRONMENT` (default `production`) targets which Sentry
# environment the alert rules apply to.
SENTRY_ENVIRONMENT=production
# `SENTRY_SLACK_*` wires the rules into the Slack workspace integration
# Sentry installed under Settings тЖТ Integrations тЖТ Slack. Leave empty to
# create email-only alert rules; provide all three to enable Slack
# delivery for both warn and crit channels.
SENTRY_SLACK_WORKSPACE=
SENTRY_SLACK_CHANNEL_WARN=
SENTRY_SLACK_CHANNEL_CRIT=

# Neon (CI smoke tests) тАФ project id from console.neon.tech project URL.
# CI reads the same value from the GitHub repo variable NEON_PROJECT_ID.
# NEON_API_KEY is set only as a GitHub repo secret, never stored here.
# This sample is documentation-only тАФ `scripts/test-neon-smoke.mjs`
# derives the project from `DATABASE_URL` rather than reading this var
# directly, so leaving it unset locally is fine.
NEON_PROJECT_ID=...

# Resend (Email)
RESEND_API_KEY=re_...
# Default `From` address for transactional email. Optional in dev (falls
# back to `Cavaliq <onboarding@resend.dev>`, Resend sandbox sender).
# REQUIRED in prod тАФ `lib/email.ts` refuses to send when unset. Use a
# verified domain: `Cavaliq <no-reply@cavaliq.com>`.
EMAIL_FROM=

# Daily livery-billing cron
# Shared secret that worker-entry.mjs's scheduled() sends as `x-cron-secret`
# on its daily 02:00 UTC ping to /api/cron/livery-billing. Generate with
# `openssl rand -hex 32`. Required in prod тАФ without it the cron route 503s.
CRON_SECRET=

# Webhook claim recovery window (milliseconds). After this, a webhook
# event in `received` state is treated as crashed and re-claimable by
# the next delivery. Default 300000 (5 min). Audit H-3.
WEBHOOK_STALE_AFTER_MS=

# Sentry (Error Tracking)
SENTRY_DSN=https://...
NEXT_PUBLIC_SENTRY_DSN=https://...
# The three below are used only at build time to upload source maps. Safe to
# leave blank in dev; the Sentry wrapper becomes a no-op.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Upstash Redis (Rate Limiting)
# Without these, rate limiting falls back to per-instance in-memory тАФ OK for
# dev but does NOT effectively throttle across serverless instances.
# Generate at https://console.upstash.com/redis (REST API enabled).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Encryption
# Required at runtime (not just build time) for any code path that
# touches encrypted-at-rest fields: rider medical notes, horse health
# records / medications / vet notes, and per-club Stripe / N-Genius /
# Ziina API credentials in club_payment_accounts.encrypted_credentials.
# Audit F-62 (2026-05-07 r5): `assertEncryptionKeyConfigured` is
# enforced at request time тАФ leaving this unset in dev does NOT crash
# at boot, but the first request that decrypts (e.g. opening a horse
# health tab, creating a medication, paying a booking) will throw.
# Set this to a 32-byte (256-bit) key encoded as 64 hex chars even for
# local dev when working on health / payments features. Generate with
# `openssl rand -hex 32`. Distinct from
# `PLATFORM_ZIINA_WEBHOOK_SECRET` тАФ that's a Ziina HMAC, this is the
# AES-GCM data-at-rest key.
ENCRYPTION_KEY=...

# Mobile (Expo)
# `EXPO_PUBLIC_*` are statically inlined into the app bundle at build time.
# `EXPO_PUBLIC_API_URL` must point at the deployed dashboard origin in
# production builds тАФ apps/mobile/lib/api.ts throws at startup when it's
# missing in non-dev. Dev builds (Expo Go, simulator) fall back to localhost.
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Sentry for React Native. `EXPO_PUBLIC_SENTRY_DSN` is the project DSN тАФ if
# unset the mobile Sentry init is a no-op (dev convenience). Set to your
# project DSN for TestFlight / production builds via `eas.json` or `.env`.
# `EXPO_PUBLIC_SENTRY_DEBUG=1` enables Sentry's verbose console output тАФ
# leave unset (or 0) outside of debugging sessions; it is noisy.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DEBUG=
