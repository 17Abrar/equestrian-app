# App
# Prod: https://cavaliq.com — see DEPLOY.md for the full Cloudflare setup.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Clerk (Auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Database (Neon)
DATABASE_URL=postgresql://...
DATABASE_URL_UNPOOLED=postgresql://...

# Cloudflare R2 (File Storage)
R2_ENDPOINT=https://...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=...
R2_PUBLIC_URL=https://...

# Stripe (Payments)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY enables the inline Stripe Elements
# pay-dialog (pay-booking-dialog.tsx loads it via @stripe/stripe-js).
# When unset, the dashboard's payment-connect UI silently falls through
# to N-Genius / Ziina; clubs that have completed Stripe Connect OAuth
# will see "Stripe disabled, contact support" until this is configured.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CLIENT_ID=ca_...  # OAuth client id from https://dashboard.stripe.com/settings/connect

# N-Genius (Network International — UAE)
# Outlet reference + API key come from the merchant portal; stored per-club.
# Override base URL for sandbox testing.
N_GENIUS_API_BASE_URL=https://api-gateway.ngenius-payments.com

# Ziina (UAE fintech)
ZIINA_API_BASE_URL=https://api-v2.ziina.com

# CORS allowlist (comma-separated origins that may call our API)
CORS_ALLOWED_ORIGINS=

# Sentry alert-rules setup (scripts/setup-sentry-alerts.mjs).
# Generate at Settings → Account → API → Auth Tokens, scopes
# `alerts:write` + `project:read`. Falls back to SENTRY_AUTH_TOKEN if
# unset, but a separate user token is preferred so it doesn't share
# the build-time org token's lifecycle.
SENTRY_ALERTS_AUTH_TOKEN=sntryu_...
SENTRY_ORG_SLUG=cavaliq
SENTRY_PROJECT_SLUG=javascript-nextjs
# EU-region orgs must point at the regional API host.
SENTRY_BASE_URL=https://de.sentry.io
# Optional knobs for setup-sentry-alerts.mjs — see audit F-4.
# `SENTRY_ENVIRONMENT` (default `production`) targets which Sentry
# environment the alert rules apply to.
SENTRY_ENVIRONMENT=production
# `SENTRY_SLACK_*` wires the rules into the Slack workspace integration
# Sentry installed under Settings → Integrations → Slack. Leave empty to
# create email-only alert rules; provide all three to enable Slack
# delivery for both warn and crit channels.
SENTRY_SLACK_WORKSPACE=
SENTRY_SLACK_CHANNEL_WARN=
SENTRY_SLACK_CHANNEL_CRIT=

# Neon (CI smoke tests) — project id from console.neon.tech project URL.
# CI reads the same value from the GitHub repo variable NEON_PROJECT_ID.
# NEON_API_KEY is set only as a GitHub repo secret, never stored here.
# This sample is documentation-only — `scripts/test-neon-smoke.mjs`
# derives the project from `DATABASE_URL` rather than reading this var
# directly, so leaving it unset locally is fine.
NEON_PROJECT_ID=...

# Resend (Email)
RESEND_API_KEY=re_...
# Default `From` address for transactional email. Optional in dev (falls
# back to `Cavaliq <onboarding@resend.dev>`, Resend sandbox sender).
# REQUIRED in prod — `lib/email.ts` refuses to send when unset. Use a
# verified domain: `Cavaliq <no-reply@cavaliq.com>`.
EMAIL_FROM=

# Daily livery-billing cron
# Shared secret that worker-entry.mjs's scheduled() sends as `x-cron-secret`
# on its daily 02:00 UTC ping to /api/cron/livery-billing. Generate with
# `openssl rand -hex 32`. Required in prod — without it the cron route 503s.
CRON_SECRET=

# Webhook claim recovery window (milliseconds). After this, a webhook
# event in `received` state is treated as crashed and re-claimable by
# the next delivery. Default 300000 (5 min). Audit H-3.
WEBHOOK_STALE_AFTER_MS=

# Sentry (Error Tracking)
SENTRY_DSN=https://...
NEXT_PUBLIC_SENTRY_DSN=https://...
# The three below are used only at build time to upload source maps. Safe to
# leave blank in dev; the Sentry wrapper becomes a no-op.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Upstash Redis (Rate Limiting)
# Without these, rate limiting falls back to per-instance in-memory — OK for
# dev but does NOT effectively throttle across serverless instances.
# Generate at https://console.upstash.com/redis (REST API enabled).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Encryption
ENCRYPTION_KEY=...

# Mobile (Expo)
# `EXPO_PUBLIC_*` are statically inlined into the app bundle at build time.
# `EXPO_PUBLIC_API_URL` must point at the deployed dashboard origin in
# production builds — apps/mobile/lib/api.ts throws at startup when it's
# missing in non-dev. Dev builds (Expo Go, simulator) fall back to localhost.
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
