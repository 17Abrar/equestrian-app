{
  "name": "@equestrian/db",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./queries": "./src/queries/index.ts",
    "./crypto": "./src/crypto.ts"
  },
  "scripts": {
    "db:generate": "node -e \"console.error('drizzle-kit generate is disabled. The migrations/meta/_journal.json snapshot files only cover 0000-0005; running generate against the current TS schema would emit a destructive diff that recreates everything since 0006. Hand-write SQL migrations in packages/db/migrations/ and mirror in packages/db/src/schema/. See packages/db/README.md.'); process.exit(1);\"",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@equestrian/shared": "workspace:*",
    "@neondatabase/serverless": "0.10.4",
    "drizzle-orm": "0.45.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.4.4",
    "@equestrian/eslint-config": "workspace:*",
    "@equestrian/typescript-config": "workspace:*",
    "@types/ws": "^8.18.1",
    "dotenv": "^16.5.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.24.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  }
}
