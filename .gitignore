# Dependencies
node_modules/

# Build outputs
.next/
.open-next/
.wrangler/
dist/
.turbo/
*.tsbuildinfo

# Cloudflare Workers generated types
**/cloudflare-env.d.ts

# Expo
.expo/
ios/
android/

# Environment variables — catches all .env* variants except the committed
# sample. Backups (.env.local.bak), swap files (.env.local.swp), and
# uncommon shapes like .env.production are all covered. The negation keeps
# .env.example tracked.
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
# Audit 2026-05-13: macOS Finder / iCloud Drive sync collision filenames
# (e.g. "FIXES_PASS_8_2026_05_11 2.md"). Catch any "<name> N.<ext>" shape
# so they don't get accidentally committed alongside the original.
"* [0-9].md"
"* [0-9].ts"
"* [0-9].tsx"
"* [0-9].txt"

# IDE
.vscode/settings.json
.idea/

# Coverage
coverage/

# Drizzle
drizzle/meta/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Sentry
.sentryclirc

# Claude Code local state — settings + scheduled task lock are per-laptop.
.claude/
